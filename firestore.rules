rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow logged-in users to create a site.
    // They must set themselves as the owner.
    match /sites/{siteId} {
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      
      // Allow any logged-in user to read site metadata (needed for invite codes)
      allow read: if request.auth != null;

      // Allow update if the user is in the memberIds list, is owner/admin,
      // OR they are joining (appending their UID to memberIds)
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.memberIds ||
        request.auth.uid == resource.data.ownerId ||
        request.auth.uid == resource.data.adminId ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds']) &&
          request.resource.data.memberIds.hasAll(resource.data.memberIds) &&
          request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1 &&
          request.auth.uid in request.resource.data.memberIds
        )
      );
      
      // Allow delete if the user is the owner or admin.
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.ownerId ||
        request.auth.uid == resource.data.adminId
      );

      // Secure nodes subcollection
      match /nodes/{nodeId} {
        // Any member of the site can read, create, update, or delete nodes.
        allow read, write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/sites/$(siteId)).data.memberIds ||
          request.auth.uid == get(/databases/$(database)/documents/sites/$(siteId)).data.ownerId ||
          request.auth.uid == get(/databases/$(database)/documents/sites/$(siteId)).data.adminId
        );
      }
    }
  }
}
